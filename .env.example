# ── PostgreSQL ─────────────────────────────────────────────
# Copiá este archivo como .env y completá los valores.
# NUNCA subas el .env al repositorio.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=che_rembiu
POSTGRES_USER=cheuser
POSTGRES_PASSWORD=chepass

# ── Google Gemini API ───────────────────────────────────────
# Obtené tu API key gratuita en: https://aistudio.google.com
GEMINI_API_KEY=tu_api_key_aqui
